{
  "name": "answer-generator",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @answer-generator/web dev",
    "api:install": "/usr/bin/python3 -m venv apps/api/.venv && apps/api/.venv/bin/python -m pip install -r apps/api/requirements.txt",
    "dev:api": "cd apps/api && ./.venv/bin/python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8001",
    "build": "pnpm -r --if-present build",
    "db:generate": "pnpm --filter @answer-generator/db db:generate",
    "db:migrate": "pnpm --filter @answer-generator/db db:migrate",
    "test": "pnpm --filter @answer-generator/shared test && cd apps/api && python3 -m pytest",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
